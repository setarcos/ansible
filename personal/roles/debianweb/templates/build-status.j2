server {
    listen 80;
    listen [::]:80;
    server_name {{ nginx_server_name }};

    location /static/ {
        alias /var/www/status/static/;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/var/www/status/build-status.sock;
    }

    location /edit {
        allow 10.88.0.0/16;
        deny all;

        include proxy_params;
        proxy_pass http://unix:/var/www/status/build-status.sock;
    }

    location /add {
        allow 10.88.0.0/16;
        deny all;

        include proxy_params;
        proxy_pass http://unix:/var/www/status/build-status.sock;
    }

    location /delete {
        allow 10.88.0.0/16;
        deny all;

        include proxy_params;
        proxy_pass http://unix:/var/www/status/build-status.sock;
    }
}

